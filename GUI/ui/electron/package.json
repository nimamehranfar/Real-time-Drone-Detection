{
    "name": "drone-detection",
    "version": "1.0.0",
    "description": "Intelligent Video Analysis System for Drone Detection",
    "main": "main.js",
    "scripts": {
        "start": "electron .",
        "build": "electron-builder"
    },
    "build": {
        "appId": "com.dronedetect.app",
        "productName": "Drone Detection",
        "win": {
            "target": "portable",
            "icon": "icon.ico"
        },
        "files": [
            "main.js",
            "preload.js"
        ],
        "extraResources": [
            {
                "from": "../backend",
                "to": "backend"
            },
            {
                "from": "../frontend/dist",
                "to": "frontend"
            }
        ]
    },
    "devDependencies": {
        "electron": "^28.0.0",
        "electron-builder": "^24.9.1"
    }
}